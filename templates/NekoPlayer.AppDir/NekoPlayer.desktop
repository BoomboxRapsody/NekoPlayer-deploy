# Desktop Entry Specification: https://standards.freedesktop.org/desktop-entry-spec/desktop-entry-spec-latest.html
[Desktop Entry]
Version=1.5
Type=Application
Name=NekoPlayer
Comment=The enhanced YouTube video player
Icon=youtube-player-ex
Exec=NekoPlayer %u
Terminal=false
Categories=AudioVideo;
StartupWMClass=NekoPlayer
SingleMainWindow=true
StartupNotify=true
